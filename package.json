{
  "name": "ubiplus",
  "version": "1.0.0",
  "description": "Ubiqam Fleet Monitor",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-packager . UbiPlus --platform=win32 --arch=x64 --out=dist --electron-version=28.3.3 --overwrite --no-asar --ignore=node_modules --ignore=dist --ignore=.git"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "@electron/packager": "^18.0.0"
  },
  "build": {
    "appId": "il.ubiqam.ubiplus",
    "productName": "UbiPlus",
    "asar": false,
    "win": {
      "target": "dir"
    },
    "files": [
      "main.js",
      "package.json",
      "server.ps1",
      "ubiplus/**"
    ]
  }
}
